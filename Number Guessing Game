import random

def play_game():
    lower_bound, upper_bound = 1, 100
    secret_number = random.randint(lower_bound, upper_bound)
    attempts = 0
    max_attempts = 7

    print(f"Guess the number between {lower_bound} and {upper_bound} in {max_attempts} tries.")

    while attempts < max_attempts:
        try:
            guess = int(input("Enter your guess: "))
            attempts += 1
            if guess == secret_number:
                print(f"Correct! You won in {attempts} tries.")
                return
            print("Too low!" if guess < secret_number else "Too high!")
        except ValueError:
            print("Invalid input.")

    print(f"Game over! The number was {secret_number}.")

play_game()
